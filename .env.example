# Keep the MVP simple: one LLM provider by default.
LLM_PROVIDER=deepseek

# Project Understanding Agent, Script Writer Agent, Storyboard Agent, Verifier Agent.
# DeepSeek is OpenAI-compatible and is the first test provider for this project.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro
DEEPSEEK_MODEL_GENERATION=deepseek-v4-flash

# Optional future provider for high-quality reasoning/TTS.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_REASONING=gpt-5.2
OPENAI_MODEL_GENERATION=gpt-5-mini

# TTS step. Edge TTS does not need an API key.
# Common Mandarin voices: zh-CN-XiaoxiaoNeural, zh-CN-YunyangNeural, zh-CN-YunxiNeural.
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+25%

# Planned pacing mode: short_30s, standard_60s, or technical_90s.
VIDEO_MODE=standard_60s

# Web UI brand mode: rs for Repo to Shorts, rb for the playful Repo to Bombs hook.
BRAND_MODE=rs
BOMB_CIRCLE=科技圈
BOMB_AGAIN_COUNT=1
RB_TTS_VOICE=zh-CN-YunxiNeural
RB_TTS_RATE=+38%
RB_HOOK_DURATION_SECONDS=3.0

# Render profile: preview is faster for editing; final keeps 1080x1920/30fps for export.
RENDER_PROFILE=final
REMOTION_CONCURRENCY=

# Repair Agent: when Verifier blocks high unsupported claims, try one evidence-only rewrite.
REPAIR_ENABLED=true
REPAIR_MAX_ATTEMPTS=1

# Optional future TTS provider keys.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
ELEVENLABS_API_KEY=

RENDERER_DIR=renderer
FRONTEND_DIR=frontend
OUTPUTS_DIR=outputs
REPO_CACHE_DIR=.cache/repos

# Optional portable tool paths. scripts/install-portable-tools.ps1 downloads tools under .tools/
# and can update these values automatically.
NODE_EXE=
NPM_CMD=
FFMPEG_EXE=
CHROME_EXE=

# Public GitHub clone does not need this. Keep it for later private repo support.
GITHUB_TOKEN=

# Optional FastAPI web UI server.
GVA_WEB_HOST=127.0.0.1
GVA_WEB_PORT=7860
