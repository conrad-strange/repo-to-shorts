# Keep the MVP simple: one LLM provider by default.
LLM_PROVIDER=deepseek

# Project Understanding Agent, Script Writer Agent, Storyboard Agent, Verifier Agent.
# DeepSeek is OpenAI-compatible and is the first test provider for this project.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro
DEEPSEEK_MODEL_GENERATION=deepseek-v4-flash

# Optional future provider for high-quality reasoning/TTS.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_REASONING=gpt-5.2
OPENAI_MODEL_GENERATION=gpt-5-mini

# TTS step. Edge TTS does not need an API key.
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+25%

# Local scene enhancement layer. The current MVP uses local HTML scenes embedded
# by Remotion; later this adapter can call the real HyperFrames CLI.
SCENE_ENHANCER=hyperframes-lite
HYPERFRAMES_CMD=

# Optional future TTS provider keys.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
ELEVENLABS_API_KEY=

RENDERER_DIR=renderer
OUTPUTS_DIR=outputs
REPO_CACHE_DIR=.cache/repos

# Optional portable tool paths. The install script writes tools under .tools/.
NODE_EXE=
NPM_CMD=
FFMPEG_EXE=
CHROME_EXE=

# Public GitHub clone does not need this. Keep it for later private repo support.
GITHUB_TOKEN=
